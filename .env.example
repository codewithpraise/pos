# ─── REQUIRED: Core Security Primitives ───────────────────────────────────────
SERVER_MASTER_KEY=       # 64 hex chars (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=              # 64+ char random string. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SYNC_SALT=               # 32 hex chars (16 bytes). Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
SYNC_PASSPHRASE=         # 16-128 printable chars. Set same value on all terminals in your mesh.

# ─── REQUIRED: Runtime ────────────────────────────────────────────────────────
NODE_ENV=production      # NEVER set to development in production deployments
PORT=3000
STORE_TERMINAL_ID=terminal_pc_master

# ─── OPTIONAL: TLS ────────────────────────────────────────────────────────────
USE_HTTPS=true           # Set to true and provide key.pem + cert.pem for HTTPS/WSS
FRONTEND_URL=            # Set to your domain if exposing to internet (e.g., https://pos.example.com)

# ─── OPTIONAL: FBR Integration ────────────────────────────────────────────────
FBR_API_URL=https://gw.fbr.gov.pk/imsapi/dvr/invoice-add
FBR_API_TOKEN=           # Obtain from FBR PRAL portal

# ─── OPTIONAL: Cloud P2P Backup (Supabase) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── OPTIONAL: Logging & Monitoring ──────────────────────────────────────────
LOG_LEVEL=info           # debug | info | warn | error
DATA_RETENTION_DAYS=90  # Days to retain audit logs, telemetry, and rate limit records

# ─── LICENSE KEYGEN (Developer Tool Only — Never Set in Production Server) ─────
LICENSE_PRIVATE_KEY_PATH=  # Defaults to ~/.valenixia/.license-private.pem. Override for air-gapped key storage.

# ─── TEST CREDENTIALS (Only Used in NODE_ENV=test or NODE_ENV=development) ────
# These are auto-generated by server.js in non-production environments.
# DO NOT set in production. These values have no effect when NODE_ENV=production.
# TEST_ADMIN_PIN=          # Required for: TEST_ADMIN_PIN=xxxx npm run test:e2e
# TEST_LICENSE_KEY=
# TEST_PASSPHRASE=
# TEST_HWIDS=