# Required for security & cryptographic operations
SERVER_MASTER_KEY=                        # 64 hex chars (32 bytes) for encrypting credentials at rest
JWT_SECRET=                               # 64+ char random string for signing JSON Web Tokens
SYNC_SALT=                                # 32 hex chars (16 bytes) for key derivation
NODE_ENV=production

# Optional but recommended
FBR_API_URL=https://gw.fbr.gov.pk/imsapi/dvr/invoice-add
FBR_API_TOKEN=
LOG_LEVEL=info
PORT=3000
USE_HTTPS=false

# Supabase (optional for cloud P2P backup sync)
SUPABASE_URL=
SUPABASE_ANON_KEY=
STORE_TERMINAL_ID=terminal_pc_master