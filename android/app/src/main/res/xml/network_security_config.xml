<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP only for local development loopback/emulator -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>

    <!-- Allowed domains for backend APIs using standard system CA validation -->
    <domain-config>
        <domain includeSubdomains="true">gw.fbr.gov.pk</domain>
        <domain includeSubdomains="true">googleapis.com</domain>
    </domain-config>

    <!-- Deny all other cleartext traffic globally -->
    <base-config cleartextTrafficPermitted="false"/>
</network-security-config>
